{
  "name": "makeyoubetter",
  "version": "1.0.0",
  "description": "MakeYouBetter - habit tracking with JWT auth (beginner-friendly stack)",
  "main": "backend/server.js",
  "scripts": {
    "dev": "nodemon backend/server.js",
    "dev:all": "concurrently \"npm run dev\" \"cd ml_service && .\\venv\\Scripts\\python app.py\"",
    "start": "node backend/server.js",
    "reset-passwords": "node backend/utils/resetAllPasswords.js",
    "mongo:up": "docker compose up -d",
    "mongo:down": "docker compose down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.10.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.7"
  }
}
